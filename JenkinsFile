pipeline {
    agent any

    stages {

        stage('Build') {
            steps {
                sh '''
                echo "Building Java project..."
                cd "Password Protection"

                mkdir -p build

                # Compile only main source files
                javac -d build src/Cryptoalgo.java src/Main.java

                echo "Build successful"
                '''
            }
        }

        stage('Test') {
            steps {
                sh '''
                echo "Running JUnit tests..."
                cd "Password Protection"

                # Remove old jar if exists
                rm -f junit-platform-console-standalone.jar

                # Download fresh JUnit Console
                curl -L -o junit-platform-console-standalone.jar https://repo1.maven.org/maven2/org/junit/platform/junit-platform-console-standalone/1.10.0/junit-platform-console-standalone-1.10.0.jar

                mkdir -p test-build

                # Compile test files with JUnit in classpath
                javac -cp junit-platform-console-standalone.jar:build -d test-build src/*Test.java

                # Run tests
                java -jar junit-platform-console-standalone.jar -cp build:test-build --scan-classpath
                '''
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                echo "Deploying application..."
                echo "Deployment successful!"
                '''
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully!'
        }
        failure {
            echo 'Pipeline failed!'
        }
    }
}
